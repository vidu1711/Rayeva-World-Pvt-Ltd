# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-systems

# AI: use one of the following (Gemini is free tier friendly)
# OpenAI (key starts with sk-)
OPENAI_API_KEY=sk-your-openai-api-key-here
# Google Gemini (key starts with AIzaSy) – can also set OPENAI_API_KEY=AIzaSy...
# GEMINI_API_KEY=AIzaSy-your-google-api-key-here